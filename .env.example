# Meta Ads Library API token (free — see README)
META_ADS_TOKEN=your_meta_ads_token_here

# AliExpress API (optional)
ALI_APP_KEY=your_aliexpress_app_key
ALI_APP_SECRET=your_aliexpress_app_secret

# Scraper settings
SCRAPER_DELAY=2          # seconds between requests (be polite)
MAX_STORES_PER_RUN=50
MIN_SCORE_THRESHOLD=40   # only save products scoring above this
